generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String
  baseCurrency  String   @default("CNY")
  targetAlloc   String?
  targetAmount  Float?           // ✨ 新增：目标金额
  riskFreeRate  Float    @default(0.025)  // ✨ 无风险利率，用于夏普
  createdAt     DateTime @default(now())
  assets        Asset[]
  transactions  Transaction[]
  snapshots     Snapshot[]
  dividends     Dividend[]
}

model Asset {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String
  name         String
  category     String   // STOCK / ETF / FUND / BOND / CRYPTO / CASH / DEPOSIT / DIVIDEND_STOCK / OTHER
  currency     String
  quantity     Float
  costPrice    Float
  manualPrice  Float?

  // ✨ 定存专用字段
  interestRate Float?           // 年化利率，如 0.025 表示 2.5%
  startDate    DateTime?        // 起息日
  endDate      DateTime?        // 到期日
  compoundType String?          // SIMPLE 单利 / COMPOUND 复利，默认 SIMPLE

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  transactions Transaction[]
  dividends    Dividend[]
  @@index([userId])
}

// ✨ 新增：分红记录
model Dividend {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  exDate      DateTime               // 除息日
  payDate     DateTime               // 派息日
  perShare    Float                  // 每股股息（原币种）
  totalAmount Float                  // 应付总额
  taxAmount   Float    @default(0)   // 扣税
  netAmount   Float                  // 到手金额
  action      String                 // CASH / REINVEST / RECORD
  reinvestPrice Float?               // 复投价格（action=REINVEST 时用）
  note        String?
  createdAt   DateTime @default(now())
  @@index([userId, payDate])
}

// Transaction / Snapshot 保持原样

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type      String
  quantity  Float
  price     Float
  fee       Float    @default(0)
  date      DateTime
  note      String?

  @@index([userId, date])
}

model Snapshot {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  totalValue  Float
  totalCost   Float
  breakdown   String

  @@unique([userId, date])
  @@index([userId, date])
}
