generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String
  baseCurrency  String   @default("CNY")
  targetAlloc   String?
  targetAmount  Float?
  riskFreeRate  Float    @default(0.025)
  createdAt     DateTime @default(now())
  assets        Asset[]
  transactions  Transaction[]
  snapshots     Snapshot[]
  dividends     Dividend[]
  plans         InvestmentPlan[]
  cashFlows     CashFlow[]
}

model Asset {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol       String
  name         String
  category     String
  currency     String
  quantity     Float
  costPrice    Float
  manualPrice  Float?

  interestRate Float?
  startDate    DateTime?
  endDate      DateTime?
  compoundType String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  transactions Transaction[]
  dividends    Dividend[]
  plans         InvestmentPlan[] @relation("PlanTargetAsset")
  fromPlans     InvestmentPlan[] @relation("PlanFromAsset")

  @@index([userId])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type      String
  quantity  Float
  price     Float
  fee       Float    @default(0)
  date      DateTime
  note      String?

  @@index([userId, date])
}

model Snapshot {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  totalValue  Float
  totalCost   Float
  netFlow     Float    @default(0)   // 新增：当日外部净流入(折算到 baseCurrency)
  breakdown   String

  @@unique([userId, date])
  @@index([userId, date])
}

model Dividend {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  exDate        DateTime
  payDate       DateTime
  perShare      Float
  totalAmount   Float
  taxAmount     Float    @default(0)
  netAmount     Float
  action        String
  reinvestPrice Float?
  note          String?
  createdAt     DateTime @default(now())

  @@index([userId, payDate])
}

model InvestmentPlan {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset    @relation("PlanTargetAsset", fields: [assetId], references: [id], onDelete: Cascade)
  fromAssetId   String?
  fromAsset     Asset?   @relation("PlanFromAsset", fields: [fromAssetId], references: [id])
  name          String
  amount        Float
  frequency     String
  dayOfMonth    Int?
  dayOfWeek     Int?
  startDate     DateTime
  endDate       DateTime?
  active        Boolean   @default(true)
  lastExecuted  DateTime?
  executedCount Int       @default(0)
  totalInvested Float     @default(0)
  createdAt     DateTime  @default(now())


  @@index([userId, active])
}

model CashFlow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  type      String   // DEPOSIT=工资/转入  WITHDRAW=消费/转出
  amount    Float    // 原币种金额，正数
  currency  String   @default("CNY")
  note      String?
  createdAt DateTime @default(now())

  @@index([userId, date])
}